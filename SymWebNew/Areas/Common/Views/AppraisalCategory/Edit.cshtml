@model SymViewModel.Common.AppraisalCategoryVM
@using UIHelper.MVC
@{
    ViewBag.Title = "Edit";
}

@using (Html.BeginForm("Edit", "AppraisalCategory", FormMethod.Post, new { enctype = "multipart/form-data", @Id = "frmAppraisal" }))
{    @Html.ValidationSummary(true)

    <div class="headrow">
        <button type="submit" title="Update Data" class="sym-btn-edit">&nbsp;Update</button>
        <label class="pull-right"> Appraisal > Category Edit</label>
    </div>

    <div class="thinbox">
        <div class="th_thinbox">
            <p>Appraisal Question Edit</p>
            @Html.HiddenFor(model => model.Id)
        </div>
        <div class="branch">
            <div class="row">
                <div class="col-md-6">
                    <div class="editor-label">
                        @Html.LabelFor(model => model.CategoryName)
                    </div>
                    <div class="editor-field">
                        @Html.TextBoxFor(model => model.CategoryName, new { @placeholder = "Category Name", @class = "required form-control" })
                        @Html.ValidationMessageFor(model => model.CategoryName)
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="editor-label">
                        @Html.LabelFor(model => model.Description)
                    </div>
                    <div class="editor-field">
                        @Html.TextAreaFor(model => model.Description, new { @placeholder = "Mark", @class = " form-control" })
                        @Html.ValidationMessageFor(model => model.Description)
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="editor-label">
                        @Html.LabelFor(model => model.Remark)
                    </div>
                    <div class="editor-field">
                        @Html.TextAreaFor(model => model.Remark, new { @placeholder = "Remark", @class = " form-control" })
                        @Html.ValidationMessageFor(model => model.Remark)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="headrow">
        <button type="submit" title="Update Data" class="sym-btn-edit">&nbsp;Update</button>
    </div>
}

<script>
    $(function () {
        valiDation("frmAppraisal");
    });
</script>