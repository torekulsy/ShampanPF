


<html xmlns:v="urn:schemas-microsoft-com:vml"
xmlns:o="urn:schemas-microsoft-com:office:office"
xmlns:w="urn:schemas-microsoft-com:office:word">
<meta http-equiv="content-type" content="text/html; charset=UTF-8" />
<head>

    <style type="text/css">
        Body {
            background-color: #FFFFFF;
            margin-left: 0px;
            margin-top: 10px;
            margin-right: 0px;
            margin-bottom: 10px;
            font-family: Verdana, Arial, Helvetica, sans-serif;
            color: #666666;
        }

        .BDJApplicantsName {
            background: #ffffff;
            font-size: 18px;
            font-weight: bold;
            color: #0b5f8a;
            padding-left: 7px;
            padding-top: 16px;
            padding-bottom: 3.5px;
        }

        .BDJHeadline01 {
            background: #f5f5f5;
            font-size: 12px;
            font-weight: bold;
            padding-left: 2px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .BDJBoldText01 {
            font-size: 11px;
            font-weight: bold;
            padding-left: 2px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .BDJNormalText01 {
            font-size: 11px;
            font-weight: normal;
            padding-left: 2px;
            padding-top: 7px;
            padding-bottom: 10px;
        }

        .BDJNormalText02 {
            font-size: 11px;
            font-weight: normal;
            padding-left: 2px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .BDJNormalText03 {
            font-size: 11px;
            font-weight: normal;
            padding-left: 7px;
            padding-top: 2px;
            padding-bottom: 2px;
        }

        .BDJNormalText04 {
            font-size: 9px;
            font-weight: normal;
            padding-left: 7px;
            padding-top: 2px;
            padding-bottom: 2px;
            height:2px
        }

        .BDJCopyRight {
            font-size: 9px;
            font-weight: normal;
            padding-left: 7px;
            padding-top: 2px;
            padding-bottom: 2px;
            color: #000066;
        }

        .tableWithBorder {
            border-top: 1px solid #dddddd;
            border-left: 1px solid #dddddd;
            border-bottom: 1px solid #dddddd;
            font-size: 11px;
            font-weight: normal;
        }

        .tableColumnHead {
            border-right: 1px solid #dddddd;
        }

        .tableGeneralCell {
            border-right: 1px solid #dddddd;
            border-top: 1px solid #dddddd;
        }

    
		em 
		{
		font-style: normal;/* / Removes italics /*/
		text-decoration: underline; /*/ Makes underline /*/
        } 
        .sr-only{
            display:none;
        }
 
    </style>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=iso-8859-1">
<meta charset="utf-8">

 
