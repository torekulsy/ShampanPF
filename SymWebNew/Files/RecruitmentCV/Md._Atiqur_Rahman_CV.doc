<script>
var g_GCPDomainNameForJs='https://mybdjobs.bdjobs.com';
var g_GCPPhotosDomainNameForJs='https://my.bdjobs.com/';
var g_GCPDomainNameWithOutHttpsForJs = 'mybdjobs.bdjobs.com'
</script>

